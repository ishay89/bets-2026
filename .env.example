# Get these values from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of admin email addresses (optional)
ADMIN_EMAILS=admin@example.com

# Optional: enables the GIF picker on the message board
NEXT_PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# Optional: enables Cloudflare R2 video uploads on the message board
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_BUCKET=your-r2-bucket-name
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com

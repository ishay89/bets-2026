# Get these values from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of admin email addresses (optional)
ADMIN_EMAILS=admin@example.com

# Optional: enables the GIF picker on the message board
NEXT_PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# Optional: automated results sync from football-data.org.
# FOOTBALL_DATA_API_KEY enables the "Sync from football-data.org" button on
# /admin/results and the scheduled /api/cron/sync-results job. Get a free key at
# https://www.football-data.org/client/register
# CRON_SECRET guards the cron endpoint; Vercel sends it as a Bearer token.
# FO
